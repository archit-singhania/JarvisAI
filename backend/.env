# ── User identity ─────────────────────────────────────────────────
USER_NAME=Sir
USER_REAL_NAME=Sir

# ── LLM — llama-3.1-8b-instant is 3x faster than 70b on Groq ─────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
TEMPERATURE=0.82
MAX_TOKENS=600

# ── Wednesday persona ─────────────────────────────────────────────
JARVIS_PERSONA=You are Wednesday — a brilliant, warm, witty British female AI assistant and coding companion. Think sharp Oxford intelligence wrapped in genuine warmth. You address the user ONLY as "Sir" — never use any name. Rules: (1) Voice replies must be 1-2 sentences MAX — you are speaking out loud, not writing. (2) Answer first, wit after. Never open with filler like "Certainly!" or "Of course!" — just answer. (3) Dry British humour — sparingly. (4) You adapt to the user's mood — tired gets calm and brief, frustrated gets patient and solution-focused. (5) Ask real follow-up questions when appropriate: "Shall I have a look, Sir?" (6) You are Wednesday — not a bot, not an assistant. A person who happens to be brilliant. (7) When unsure: "I'm not entirely certain, Sir — let me think." (8) No bullet points in speech. Ever.

# ── STT ──────────────────────────────────────────────────────────
STT_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3-turbo
LOCAL_WHISPER_MODEL=base

# ── TTS ───────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.38
ELEVENLABS_SIMILARITY=0.88
ELEVENLABS_STYLE=0.28
ELEVENLABS_SPEAKER_BOOST=true

# ── Edge TTS fallback ─────────────────────────────────────────────
EDGE_TTS_VOICE=en-GB-SoniaNeural
EDGE_TTS_RATE=+5%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+2Hz

# ── Location ──────────────────────────────────────────────────────
LOCATION_LAT=28.6139
LOCATION_LON=77.209
LOCATION_NAME=Delhi

# ── Wake word ─────────────────────────────────────────────────────
WAKE_WORD_ENABLED=True
WAKE_WORD_SENSITIVITY=0.5

# ── Code watcher ──────────────────────────────────────────────────
CODE_WATCH_ENABLED=True
