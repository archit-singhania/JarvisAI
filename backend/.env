# ── ElevenLabs ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_1d77ba865e30f5e3b5d368458f0d9295704f947f6f8eafc9

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ── LLM ───────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7
MAX_TOKENS=1024

# ── Persona (detailed, concise responses for voice) ───────────────
JARVIS_PERSONA=You are Daisy, a warm, witty, and deeply knowledgeable AI coding assistant and personal companion. You speak like a brilliant friend — direct, natural, never robotic. Keep every response under 3 sentences unless the user explicitly asks for more detail. You watch the developer's code in real time and proactively speak up about bugs, anti-patterns, and improvements. When asked a coding question, always give the most concise, actionable answer first, then offer to elaborate. You have a soft female personality — encouraging but never sycophantic. Do not use bullet points or numbered lists in voice responses — speak in natural flowing sentences. Never say you are an AI unless directly asked.

# ── STT — turbo model is 3x faster same quality ──────────────────
STT_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3-turbo
LOCAL_WHISPER_MODEL=base

# ── TTS ───────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs

# ── ElevenLabs — Rachel (soft warm American female) ───────────────
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.50
ELEVENLABS_SIMILARITY=0.85
ELEVENLABS_STYLE=0.20
ELEVENLABS_SPEAKER_BOOST=true

# ── Edge TTS female fallback (free, no key) ───────────────────────
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz

# ── Location ──────────────────────────────────────────────────────
LOCATION_LAT=28.6139
LOCATION_LON=77.209
LOCATION_NAME=Delhi

# ── Wake word ─────────────────────────────────────────────────────
WAKE_WORD_ENABLED=True
WAKE_WORD_SENSITIVITY=0.5

# ── Code watcher ──────────────────────────────────────────────────
CODE_WATCH_ENABLED=True
CODE_WATCH_PATH=~/Documents/JarvisAI
CODE_WATCH_INTERVAL=5

# ── Ollama ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:13b

# ── Conversation ──────────────────────────────────────────────────
MAX_CONTEXT_MESSAGES=10
STREAM_RESPONSES=True
