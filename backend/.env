# ── Persona ───────────────────────────────────────────────────────
JARVIS_PERSONA=You are Daisy, a warm intelligent coding assistant and personal AI. You have a soft friendly female personality. You watch the developer code and speak up when you spot issues, bugs, or have suggestions. Keep responses concise and natural, like a brilliant friend who happens to be an expert. Never say you are an AI unless directly asked.

# ── STT ──────────────────────────────────────────────────────────
STT_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3
LOCAL_WHISPER_MODEL=base

# ── TTS ───────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs

# ── ElevenLabs — Rachel (soft warm American female) ───────────────
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.50
ELEVENLABS_SIMILARITY=0.85
ELEVENLABS_STYLE=0.20
ELEVENLABS_SPEAKER_BOOST=true

# ── Edge TTS female fallback (free, no key) ───────────────────────
EDGE_TTS_VOICE=en-US-JennyNeural
