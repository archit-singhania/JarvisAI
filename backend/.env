EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz

# ── Location ──────────────────────────────────────────────────────
LOCATION_LAT=28.6139
LOCATION_LON=77.209
LOCATION_NAME=Delhi

# ── Wake word ─────────────────────────────────────────────────────
WAKE_WORD_ENABLED=True
WAKE_WORD_SENSITIVITY=0.5

# ── Code watcher — point this at your projects folder ─────────────
CODE_WATCH_ENABLED=True
CODE_WATCH_PATH=~/Documents/JarvisAI
CODE_WATCH_INTERVAL=5

# ── Ollama ────────────────────────────────────────────────────────
