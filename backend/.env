# ── Required ──────────────────────────────────────────────────────
GROQ_API_KEY=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

# ── ElevenLabs (free tier — 10,000 chars/month, best voice quality) ──
# Get free key at: https://elevenlabs.io  → Sign up → Profile → API Key
ELEVENLABS_API_KEY=sk_1d77ba865e30f5e3b5d368458f0d9295704f947f6f8eafc9

# ── Optional fallbacks ────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ── LLM ──────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ── Streaming ─────────────────────────────────────────────────────
STREAM_RESPONSES=True

# ── STT ──────────────────────────────────────────────────────────
STT_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3
LOCAL_WHISPER_MODEL=base

# ── TTS provider priority ─────────────────────────────────────────
# "elevenlabs" → best quality, free 10k chars/month (set ELEVENLABS_API_KEY above)
# "edge"       → Microsoft Neural, free unlimited, sounds very human
# "coqui"      → offline fallback
# "gtts"       → last resort
TTS_PROVIDER=elevenlabs

# ── ElevenLabs voice settings ─────────────────────────────────────
# Best free voices for Jarvis:
#   Adam        → deep, authoritative male (ID: pNInz6obpgDQGcFmaJgB)
#   Antoni      → clear, confident male   (ID: ErXwobaYiN019PkySvjV)
#   Josh        → friendly young male     (ID: TxGEqnHWrfWFTfGW9XjX)
#   Arnold      → strong, narrative male  (ID: VR6AewLTigWG4xSOukaG)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY=0.80
ELEVENLABS_STYLE=0.35
ELEVENLABS_SPEAKER_BOOST=true

# ── Edge TTS (fallback — no key needed) ───────────────────────────
EDGE_TTS_VOICE=en-GB-RyanNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=-5Hz

# ── Wake word ─────────────────────────────────────────────────────
WAKE_WORD_ENABLED=True
WAKE_WORD_SENSITIVITY=0.5

# ── Ollama (optional, offline) ────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:13b

# ── Context ───────────────────────────────────────────────────────
MAX_CONTEXT_MESSAGES=10
MAX_TOKENS=2048
TEMPERATURE=0.7
