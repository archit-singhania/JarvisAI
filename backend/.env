# FREE API Keys
# Get Groq API Key: https://console.groq.com/keys (FREE - for LLM)
GROQ_API_KEY=your-groq-api-key-here

# Get OpenAI API Key: https://platform.openai.com/api-keys (PAID but reliable)
OPENAI_API_KEY=your-openai-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# LLM Configuration (FREE Groq for chat)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-70b-versatile
# Other Groq options: llama-3.1-8b-instant, mixtral-8x7b-32768

# Vision Configuration (OpenAI)
VISION_PROVIDER=openai
VISION_MODEL=gpt-4o-mini

# Speech-to-Text (FREE Groq Whisper)
STT_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3

# Text-to-Speech (OpenAI TTS)
TTS_PROVIDER=openai
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Ollama (Optional - 100% FREE Local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# RAG Configuration
CHUNK_SIZE_RAG=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=text-embedding-3-small

# Wake Word
WAKE_WORD=jarvis

# Context Settings
MAX_CONTEXT_MESSAGES=10
MAX_TOKENS=8000
TEMPERATURE=0.7
