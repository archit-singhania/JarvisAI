<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Jarvis dark theme palette ─────────────────────────────── -->
  <Color x:Key="BgDeepColor">#0A0E1A</Color>
  <Color x:Key="BgPanelColor">#111827</Color>
  <Color x:Key="BgCardColor">#1C2333</Color>
  <Color x:Key="AccentCyanColor">#00D4FF</Color>
  <Color x:Key="AccentBlueColor">#3B82F6</Color>
  <Color x:Key="TextPrimaryColor">#F0F4FF</Color>
  <Color x:Key="TextSecondaryColor">#8B9DC3</Color>
  <Color x:Key="JarvisResponseColor">#00D4FF</Color>
  <Color x:Key="UserMessageColor">#3B82F6</Color>
  <Color x:Key="SuccessColor">#10B981</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BgDeep"         Color="{StaticResource BgDeepColor}"/>
  <SolidColorBrush x:Key="BgPanel"        Color="{StaticResource BgPanelColor}"/>
  <SolidColorBrush x:Key="BgCard"         Color="{StaticResource BgCardColor}"/>
  <SolidColorBrush x:Key="AccentCyan"     Color="{StaticResource AccentCyanColor}"/>
  <SolidColorBrush x:Key="AccentBlue"     Color="{StaticResource AccentBlueColor}"/>
  <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="JarvisResponse" Color="{StaticResource JarvisResponseColor}"/>
  <SolidColorBrush x:Key="UserMessage"    Color="{StaticResource UserMessageColor}"/>
  <SolidColorBrush x:Key="Success"        Color="{StaticResource SuccessColor}"/>

  <LinearGradientBrush x:Key="GlowBorderBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#00D4FF" Offset="0"/>
    <GradientStop Color="#3B82F6" Offset="1"/>
  </LinearGradientBrush>

</ResourceDictionary>
