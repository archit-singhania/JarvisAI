<Window x:Class="JarvisAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JarvisAI"
        Title="Jarvis AI" Height="780" Width="1100"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

  <Window.DataContext>
    <local:MainViewModel/>
  </Window.DataContext>

  <!-- Drop shadow outer wrapper -->
  <Border Margin="10" CornerRadius="12"
          Background="{StaticResource BgDeep}">
    <Border.Effect>
      <DropShadowEffect Color="#00D4FF" BlurRadius="24" ShadowDepth="0" Opacity="0.18"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>   <!-- title bar -->
        <RowDefinition Height="*"/>    <!-- main content -->
        <RowDefinition Height="80"/>   <!-- input bar -->
      </Grid.RowDefinitions>

      <!-- ── Title bar ──────────────────────────────────────────── -->
      <Border Grid.Row="0" Background="{StaticResource BgPanel}"
              CornerRadius="12,12,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="16,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="{StaticResource AccentCyan}" Margin="0,0,8,0"/>
            <TextBlock Text="JARVIS AI" Foreground="{StaticResource AccentCyan}"
                       FontSize="13" FontWeight="SemiBold" LetterSpacing="3"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusBadge" Text="● ONLINE"
                       Foreground="{StaticResource Success}"
                       FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <!-- Window controls -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="─" Width="32" Height="28" Click="Minimize_Click"
                    Style="{StaticResource JarvisButton}" FontSize="11" Margin="0,0,4,0"/>
            <Button Content="✕" Width="32" Height="28" Click="Close_Click"
                    Style="{StaticResource JarvisButton}" FontSize="11"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ── Main content area ──────────────────────────────────── -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>   <!-- sidebar -->
          <ColumnDefinition Width="*"/>     <!-- chat -->
          <ColumnDefinition Width="240"/>   <!-- tools panel -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="#1C2A44" BorderThickness="0,0,1,0">
          <StackPanel Margin="16,20">
            <TextBlock Text="CAPABILITIES" Foreground="{StaticResource TextSecondary}"
                       FontSize="10" LetterSpacing="2" Margin="0,0,0,12"/>
            <!-- capability buttons -->
            <Button Content="🎤  Voice Mode"     Style="{StaticResource JarvisButton}" Margin="0,0,0,8"
                    Command="{Binding SetModeCommand}" CommandParameter="voice"/>
            <Button Content="💬  Text Mode"      Style="{StaticResource JarvisButton}" Margin="0,0,0,8"
                    Command="{Binding SetModeCommand}" CommandParameter="text"/>
            <Button Content="🖥  Screen Analyze" Style="{StaticResource JarvisButton}" Margin="0,0,0,8"
                    Command="{Binding ScreenAnalyzeCommand}"/>
            <Button Content="📁  Add to Memory"  Style="{StaticResource JarvisButton}" Margin="0,0,0,8"
                    Command="{Binding AddMemoryCommand}"/>
            <Button Content="🗑  Clear Chat"     Style="{StaticResource JarvisButton}" Margin="0,24,0,0"
                    Command="{Binding ClearChatCommand}"/>

            <Separator Background="#1C2A44" Margin="0,20"/>
            <TextBlock Text="CONNECTION" Foreground="{StaticResource TextSecondary}"
                       FontSize="10" LetterSpacing="2" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource TextSecondary}"
                       FontSize="11" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- Chat area -->
        <Grid Grid.Column="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Voice waveform visualiser (shown when mic is active) -->
          <Border Grid.Row="0" x:Name="WaveformPanel" Height="60"
                  Background="{StaticResource BgPanel}"
                  Visibility="{Binding IsListening, Converter={StaticResource BoolToVisibility}}"
                  BorderBrush="#1C2A44" BorderThickness="0,0,0,1">
            <ItemsControl ItemsSource="{Binding WaveformBars}" HorizontalAlignment="Center"
                          VerticalAlignment="Center">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Rectangle Width="3" Height="{Binding}" Fill="{StaticResource AccentCyan}"
                             Margin="1,0" RadiusX="1" RadiusY="1"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <!-- Messages list -->
          <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                        Style="{StaticResource ChatScrollViewer}"
                        Padding="16,12">
            <ItemsControl ItemsSource="{Binding Messages}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,12" Padding="14,10"
                          CornerRadius="10" MaxWidth="680"
                          HorizontalAlignment="{Binding Alignment}">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding BubbleColor}"/>
                    </Border.Background>
                    <StackPanel>
                      <TextBlock Text="{Binding Sender}" FontSize="10"
                                 Foreground="{StaticResource TextSecondary}"
                                 Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding Content}" FontSize="14"
                                 Foreground="{StaticResource TextPrimary}"
                                 TextWrapping="Wrap" LineHeight="22"/>
                      <TextBlock Text="{Binding Timestamp}" FontSize="10"
                                 Foreground="{StaticResource TextSecondary}"
                                 HorizontalAlignment="Right" Margin="0,6,0,0"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>

        <!-- Tools / activity panel -->
        <Border Grid.Column="2" Background="{StaticResource BgPanel}"
                BorderBrush="#1C2A44" BorderThickness="1,0,0,0">
          <StackPanel Margin="16,20">
            <TextBlock Text="TOOL ACTIVITY" Foreground="{StaticResource TextSecondary}"
                       FontSize="10" LetterSpacing="2" Margin="0,0,0,12"/>
            <ItemsControl ItemsSource="{Binding ToolLog}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource BgCard}" CornerRadius="6"
                          Padding="10,8" Margin="0,0,0,6">
                    <TextBlock Text="{Binding}" Foreground="{StaticResource AccentCyan}"
                               FontSize="11" TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Input bar ──────────────────────────────────────────── -->
      <Border Grid.Row="2" Background="{StaticResource BgPanel}"
              BorderBrush="#1C2A44" BorderThickness="0,1,0,0"
              CornerRadius="0,0,12,12">
        <Grid Margin="16,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBox Grid.Column="0" x:Name="InputBox"
                   Style="{StaticResource ChatInput}"
                   Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                   KeyDown="InputBox_KeyDown"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0">
            <TextBox.Resources>
              <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
            </TextBox.Resources>
          </TextBox>

          <!-- Mic button -->
          <Button Grid.Column="1" Style="{StaticResource MicButton}"
                  Command="{Binding ToggleMicCommand}"
                  Margin="0,0,10,0" ToolTip="Hold to speak">
            <Button.Background>
              <SolidColorBrush Color="{Binding MicButtonColor}"/>
            </Button.Background>
            <TextBlock Text="🎤" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
          </Button>

          <!-- Send button -->
          <Button Grid.Column="2" Content="Send" Width="80"
                  Style="{StaticResource JarvisButton}"
                  Command="{Binding SendTextCommand}"
                  VerticalAlignment="Center"/>
        </Grid>
      </Border>

    </Grid>
  </Border>
</Window>
